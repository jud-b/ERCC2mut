library(ref_genome, character.only = TRUE)

# Inclde only relevant columns from the original maf_file 
# Necessary information: Chromosome, Start and End positions for each mutation, Strand information (if available), Sample name, Variant type and reference and alternative alleles
subset_maf_file <- maf_file[, c("Chromosome", "Start_Position", "End_Position", "Strand", "Tumor_Sample_Barcode", "Reference_Allele", "Tumor_Seq_Allele2", "Variant_Type")]

